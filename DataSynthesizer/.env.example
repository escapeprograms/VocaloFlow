# Path to the conda python.exe that runs SoulX-Singer inference subprocesses.
# This is the dedicated `soulxsinger` env (torch + SoulX-Singer package),
# separate from the parent `vocaloflow-datasynthesizer` orchestration env.
SOULX_PYTHON=C:\Users\<username>\miniconda3\envs\soulxsinger\python.exe

# Path to UtauGenerate.dll (compiled .NET 9 output)
UTAU_GENERATE_DLL=C:\path\to\API\UtauGenerate\bin\Release\net9.0\UtauGenerate.dll
